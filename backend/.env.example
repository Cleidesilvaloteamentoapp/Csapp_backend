# App
APP_NAME=CSApp Backend
APP_ENV=development
DEBUG=True
API_V1_PREFIX=/api/v1
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Supabase - NOVAS API KEYS
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...
SUPABASE_JWT_SECRET={"x":"...","y":"...","alg":"ES256","crv":"P-256","ext":true,"kid":"...","kty":"EC","key_ops":["verify"]}

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/csapp

# Redis
REDIS_URL=redis://localhost:6379/0

# Email
EMAIL_PROVIDER=resend
RESEND_API_KEY=your-resend-api-key
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_FROM_NAME=CSApp

# WhatsApp
# NOTE: WhatsApp provider credentials (UAZAPI and/or Meta Cloud API) are stored
# PER-COMPANY in the whatsapp_credentials table.
# Configure them via the admin API: POST /api/v1/admin/whatsapp/credentials/
# No environment variables needed – each company manages its own credentials.
# Supported providers: UAZAPI (base_url + instance_token) and META (waba_id + phone_number_id + access_token)

# Storage
SUPABASE_STORAGE_BUCKET=documents

# Sicredi
# NOTE: Sicredi API credentials (x_api_key, username, password, cooperativa, posto,
# codigo_beneficiario) are stored PER-COMPANY in the sicredi_credentials table.
# Configure them via the admin API: POST /api/v1/admin/sicredi/credentials
# No environment variables needed – each company manages its own credentials.

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
AUTH_RATE_LIMIT=5/minute

# Security
ALLOWED_HOSTS=["*"]
WEBHOOK_IP_WHITELIST=[]

# Server
PORT=8000
