# App
APP_NAME=CSApp Backend
APP_ENV=development
DEBUG=True
API_V1_PREFIX=/api/v1
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Supabase - NOVAS API KEYS
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...
SUPABASE_JWT_SECRET={"x":"...","y":"...","alg":"ES256","crv":"P-256","ext":true,"kid":"...","kty":"EC","key_ops":["verify"]}

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/csapp

# Redis
REDIS_URL=redis://localhost:6379/0

# Asaas
ASAAS_API_KEY=your-asaas-api-key
ASAAS_ENVIRONMENT=sandbox
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3

# Email
EMAIL_PROVIDER=resend
RESEND_API_KEY=your-resend-api-key
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_FROM_NAME=CSApp

# WhatsApp
WHATSAPP_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_WHATSAPP_NUMBER=+14155238886

# Storage
SUPABASE_STORAGE_BUCKET=documents

# Sicredi
# NOTE: Sicredi API credentials (x_api_key, username, password, cooperativa, posto,
# codigo_beneficiario) are stored PER-COMPANY in the sicredi_credentials table.
# Configure them via the admin API: POST /api/v1/admin/sicredi/credentials
# No environment variables needed – each company manages its own credentials.

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
